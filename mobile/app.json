{
  "expo": {
    "name": "ReelFeel",
    "slug": "reelfeel",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "supportsTablet": false,
      "bundleIdentifier": "com.reelfeel.app",
      "buildNumber": "10",
      "appleTeamId": "DS5DKR22ZZ",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:reelfeel.me",
        "webcredentials:reelfeel.me"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.reelfeel.app"
    },
    "scheme": "reelfeel",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#111827"
        }
      ],
      "./plugins/withWidgetBridge",
      [
        "@bacons/apple-targets",
        {}
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "407fbd5f-4d39-484d-a33b-a6cc17da488b"
      }
    },
    "owner": "dzidziquist",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/407fbd5f-4d39-484d-a33b-a6cc17da488b"
    }
  }
}
