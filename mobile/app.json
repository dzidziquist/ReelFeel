{
  "expo": {
    "name": "ReelFeel",
    "slug": "reelfeel",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reelfeel.app",
      "buildNumber": "9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["nflx", "aiv", "disneyplus", "hulu", "max", "videos", "peacocktv", "paramountplus", "crunchyroll", "tubi", "starz", "showtime"]
      },
      "associatedDomains": ["applinks:reelfeel.me", "webcredentials:reelfeel.me"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.reelfeel.app"
    },
    "scheme": "reelfeel",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#111827"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "407fbd5f-4d39-484d-a33b-a6cc17da488b"
      }
    },
    "owner": "dzidziquist",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/407fbd5f-4d39-484d-a33b-a6cc17da488b"
    }
  }
}
